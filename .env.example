# ============================================
# BuildOS Platform - Complete Environment Variables
# ============================================
# Copy this file to .env and fill in your values

# ============================================
# SUPABASE CONFIGURATION (Required)
# ============================================
# These are used by both apps
PUBLIC_SUPABASE_URL=https://your-project.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-anon-key
PUBLIC_SUPABASE_PROJECT_ID=your-project  # The part before .supabase.co
PRIVATE_SUPABASE_SERVICE_KEY=your-service-key


# ============================================
# AI/LLM CONFIGURATION (Required)
# ============================================
# Primary AI provider
PRIVATE_OPENROUTER_API_KEY=sk-or-...       # OpenRouter API key (primary)

# Optional direct Moonshot path for Kimi models (runs in parallel with OpenRouter routing)
PRIVATE_MOONSHOT_API_KEY=sk-...            # Moonshot API key for direct Kimi calls
PRIVATE_MOONSHOT_API_URL=https://api.moonshot.ai/v1/chat/completions
PRIVATE_MOONSHOT_ROUTE_KIMI_DIRECT=false   # true => route Kimi models directly to Moonshot

# Fallback providers
PRIVATE_OPENAI_API_KEY=sk-...              # OpenAI API key (fallback)
PRIVATE_ANTHROPIC_API_KEY=sk-ant-...       # Anthropic Claude API key (fallback)

PRIVATE_TAVILY_API_KEY=tvly-...

# Web Visit Tooling (optional)
WEB_VISIT_TIMEOUT_MS=12000
WEB_VISIT_LLM_TIMEOUT_MS=25000
WEB_VISIT_MAX_BYTES=2000000
WEB_VISIT_MAX_CHARS=6000
WEB_VISIT_MAX_HTML_CHARS=40000

# For local Ollama (optional)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama2

# ============================================
# GOOGLE OAUTH (Required for calendar)
# ============================================
# Note: Some places use PUBLIC, some use PRIVATE for client ID
PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
PRIVATE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com  # Same as PUBLIC
PRIVATE_GOOGLE_CLIENT_SECRET=your-google-secret
GOOGLE_CLIENT_SECRET=your-google-secret  # Alias for some endpoints

# ============================================
# STRIPE PAYMENTS (Optional)
# ============================================
PRIVATE_ENABLE_STRIPE=false  # Set to true to enable payments
PRIVATE_STRIPE_SECRET_KEY=sk_test_...
PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...          # Default/legacy subscription price ID
PRIVATE_STRIPE_PRO_PRICE_ID=price_...    # Pro plan price ID
PRIVATE_STRIPE_POWER_PRICE_ID=price_...  # Power plan price ID
# Legacy aliases (supported for existing setups)
# ENABLE_STRIPE=false
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PRO_PRICE_ID=price_...
# STRIPE_POWER_PRICE_ID=price_...

# ============================================
# CONSUMPTION BILLING (Optional feature flags)
# ============================================
PRIVATE_ENABLE_CONSUMPTION_BILLING_GATE=false       # Gate mutations on frozen/over-quota accounts
PRIVATE_ENABLE_CONSUMPTION_AUTO_POWER_UPGRADE=false # Auto-upgrade Pro → Power when quota exceeded

# ============================================
# AGENTIC CHAT BEHAVIORAL PROFILE (Optional)
# ============================================
AGENTIC_CHAT_BEHAVIORAL_PROFILE_MODE=off           # off | shadow | inject (start with shadow)
AGENTIC_CHAT_BEHAVIORAL_PROFILE_TIMEOUT_MS=25      # Hard timeout (ms) for profile lookup

# ============================================
# TWILIO / SMS (Optional)
# ============================================
PRIVATE_TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PRIVATE_TWILIO_AUTH_TOKEN=your_auth_token
PRIVATE_TWILIO_MESSAGING_SERVICE_SID=MGxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PRIVATE_TWILIO_VERIFY_SERVICE_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx  # Optional for phone verification
PRIVATE_TWILIO_STATUS_CALLBACK_URL=https://your-domain.com/api/webhooks/twilio/status

# SMS rate limits (optional)
PRIVATE_SMS_RATE_LIMIT_PER_MINUTE=10
PRIVATE_SMS_RATE_LIMIT_PER_HOUR=100

# ============================================
# WEB PUSH NOTIFICATIONS (Optional)
# ============================================
# Generate with: npx web-push generate-vapid-keys
PUBLIC_VAPID_PUBLIC_KEY=BN...your_public_key_here

# ============================================
# VOICE TRANSCRIPTION (Optional)
# ============================================
# Default OpenAI transcription model (gpt-4o-transcribe / gpt-4o-mini-transcribe / whisper-1)
TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
# OpenRouter-based audio transcription path
TRANSCRIPTION_USE_OPENROUTER=false
TRANSCRIPTION_OPENROUTER_MODEL=                   # Primary audio-capable OpenRouter model
TRANSCRIPTION_OPENROUTER_FALLBACK_MODELS=         # Comma-separated audio-capable fallbacks

# ============================================
# APPLICATION CONFIGURATION
# ============================================
PUBLIC_APP_URL=http://localhost:5173  # Change for production
NODE_ENV=development

# ============================================
# WORKER COMMUNICATION
# ============================================
# Development: http://localhost:3001
# Production: https://buildos-worker.up.railway.app
PUBLIC_RAILWAY_WORKER_URL=http://localhost:3001
# Auth token for web -> worker API calls (must match worker's PRIVATE_RAILWAY_WORKER_TOKEN)
PRIVATE_RAILWAY_WORKER_TOKEN=your-railway-worker-token

# Brief polling configuration (using defaults)
PUBLIC_BRIEF_POLLING_INTERVAL=5000     # 5 seconds polling interval
PUBLIC_BRIEF_MAX_POLLING_TIME=300000   # 5 minutes max polling time

# ============================================
# EMAIL CONFIGURATION (Web App)
# ============================================
# Email accounts: dj@build-os.com and zach@build-os.com
PRIVATE_DJ_GMAIL_APP_PASSWORD=your-dj-app-password
PRIVATE_ZACH_GMAIL_APP_PASSWORD=your-zach-app-password
# Sender identity for the admin Gmail integration (used by /api/admin/emails)
PUBLIC_GMAIL_USER=dj@build-os.com
# Local lifecycle email safety: dev defaults to "log"; use "gmail" only with allowlist.
PRIVATE_LIFECYCLE_EMAIL_SINK=log
PRIVATE_LIFECYCLE_DEV_ALLOWLIST=you@example.com
# Optional local SMTP sink for Mailtrap/Ethereal.
PRIVATE_LIFECYCLE_SMTP_HOST=
PRIVATE_LIFECYCLE_SMTP_PORT=587
PRIVATE_LIFECYCLE_SMTP_USER=
PRIVATE_LIFECYCLE_SMTP_PASS=
PRIVATE_LIFECYCLE_SMTP_SECURE=false
PRIVATE_LIFECYCLE_SMTP_FROM=

# ============================================
# WORKER SPECIFIC CONFIGURATION
# ============================================
PORT=3001  # Worker port
WORKER_NODE_ENV=production  # Can be different from main app

# Queue Configuration
QUEUE_POLL_INTERVAL=5000
QUEUE_BATCH_SIZE=5
QUEUE_MAX_RETRIES=3
QUEUE_RETRY_BACKOFF_BASE=1000
QUEUE_ENABLE_PROGRESS_TRACKING=true
QUEUE_PROGRESS_UPDATE_RETRIES=3
QUEUE_STATS_UPDATE_INTERVAL=60000
QUEUE_ENABLE_HEALTH_CHECKS=true
QUEUE_WORKER_TIMEOUT=600000
QUEUE_ENABLE_CONCURRENT_PROCESSING=true
QUEUE_STALLED_TIMEOUT=300000

# Worker Email Configuration - Using Webhook Method
USE_WEBHOOK_EMAIL=true
BUILDOS_WEBHOOK_URL=http://localhost:5173/webhooks/daily-brief-email  # Change to your Vercel URL in production
BUILDOS_WEBHOOK_SECRET=your-webhook-secret  # Must match PRIVATE_BUILDOS_WEBHOOK_SECRET
WEBHOOK_TIMEOUT=30000

# ============================================
# SECURITY & WEBHOOKS
# ============================================
PRIVATE_CRON_SECRET=your-random-cron-secret  # For cron job authentication
PRIVATE_BUILDOS_WEBHOOK_SECRET=your-webhook-secret  # For webhook verification

# ============================================
# DEVELOPMENT VS PRODUCTION EXAMPLES
# ============================================

# === DEVELOPMENT ===
# NODE_ENV=development
# PUBLIC_APP_URL=http://localhost:5173
# PUBLIC_RAILWAY_WORKER_URL=http://localhost:3001
# PRIVATE_ENABLE_STRIPE=false
# QUEUE_POLL_INTERVAL=2000
# QUEUE_BATCH_SIZE=2

# === PRODUCTION ===
# NODE_ENV=production
# PUBLIC_APP_URL=https://buildos.app
# PUBLIC_RAILWAY_WORKER_URL=https://buildos-worker.up.railway.app
# PRIVATE_ENABLE_STRIPE=true
# QUEUE_POLL_INTERVAL=5000
# QUEUE_BATCH_SIZE=10
