{
	"name": "buildos-platform",
	"version": "0.0.0",
	"private": true,
	"description": "BuildOS Platform - AI-powered productivity platform monorepo",
	"scripts": {
		"dev": "turbo dev",
		"build": "turbo build",
		"test": "turbo test",
		"test:run": "turbo test:run",
		"lint": "turbo lint",
		"lint:fix": "turbo lint:fix",
		"typecheck": "turbo typecheck",
		"format": "prettier --write .",
		"clean": "turbo clean",
		"pre-push": "turbo pre-push",
		"gen:types": "node --import tsx scripts/generate-types.ts",
		"gen:schema": "node --import tsx scripts/extract-database-schema.ts",
		"gen:web": "pnpm --filter=web gen:web",
		"gen:all": "pnpm run gen:types -- --allow-stale && pnpm run gen:schema && pnpm run gen:web && pnpm --filter=@buildos/shared-types build && pnpm run label-paths && pnpm format && pnpm typecheck",
		"label-paths": "node --import tsx scripts/labelFilePaths.ts"
	},
	"devDependencies": {
		"dotenv": "^16.4.5",
		"prettier": "^3.6.2",
		"prettier-plugin-svelte": "^3.4.0",
		"tsx": "^4.20.3",
		"turbo": "^2.3.3"
	},
	"packageManager": "pnpm@9.15.2",
	"engines": {
		"node": ">=20.0.0",
		"pnpm": ">=9.0.0"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild",
			"sharp"
		],
		"overrides": {
			"cookie@<0.7.0": ">=0.7.0",
			"brace-expansion@>=1.0.0 <=1.1.11": "1.1.12",
			"brace-expansion@>=2.0.0 <=2.0.1": "2.0.2",
			"form-data@>=4.0.0 <4.0.4": ">=4.0.4",
			"@eslint/plugin-kit@<0.3.4": ">=0.3.4",
			"linkifyjs@<4.3.2": ">=4.3.2",
			"glob@>=10.2.0 <10.5.0": ">=10.5.0",
			"@sveltejs/kit@<2.49.5": ">=2.49.5",
			"vite@<7.3.2": ">=7.3.2",
			"ajv@<8.18.0": ">=8.18.0",
			"axios@<1.13.5": ">=1.13.5",
			"bn.js@<4.12.3": ">=4.12.3",
			"devalue@<5.6.2": ">=5.6.2",
			"jsonwebtoken@<9.0.3": ">=9.0.3",
			"jws@>=4.0.0 <4.0.1": ">=4.0.1",
			"jws@<3.2.3": ">=3.2.3",
			"jws@4.0.0": "4.0.1",
			"lodash@<4.18.1": ">=4.18.1",
			"markdown-it@<14.1.1": ">=14.1.1",
			"path-to-regexp@>=0.1.0 <0.1.13": ">=0.1.13",
			"picomatch@<4.0.4": ">=4.0.4",
			"prismjs@<1.30.0": ">=1.30.0",
			"qs@<6.15.0": ">=6.15.0",
			"rollup@<4.59.0": ">=4.59.0",
			"serialize-javascript@<7.0.3": ">=7.0.3",
			"svelte@<5.53.5": ">=5.53.5",
			"tar@=7.5.1": ">=7.5.2",
			"webpack@<5.104.1": ">=5.104.1",
			"yaml@<2.8.3": ">=2.8.3",
			"js-yaml@>=4.0.0 <4.1.1": ">=4.1.1",
			"nodemailer@<7.0.11": ">=7.0.11"
		}
	}
}
