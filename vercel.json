{
	"$schema": "https://openapi.vercel.sh/vercel.json",
	"installCommand": "pnpm install --frozen-lockfile",
	"buildCommand": "turbo build --filter=@buildos/web...",
	"redirects": [
		{
			"source": "/apple-touch-icon-120x120.png",
			"destination": "/AppImages/ios/120.png",
			"permanent": true
		},
		{
			"source": "/apple-touch-icon-120x120-precomposed.png",
			"destination": "/AppImages/ios/120.png",
			"permanent": true
		},
		{
			"source": "/sitemap_index.xml",
			"destination": "/sitemap.xml",
			"permanent": true
		}
	],
	"crons": [
		{
			"path": "/api/cron/dunning",
			"schedule": "0 9 * * *"
		},
		{
			"path": "/api/cron/trial-reminders",
			"schedule": "0 10 * * *"
		},
		{
			"path": "/api/cron/billing-ops-monitoring",
			"schedule": "0 11 * * *"
		},
		{
			"path": "/api/cron/welcome-sequence",
			"schedule": "0 * * * *"
		},
		{
			"path": "/api/cron/reactivation-sequence",
			"schedule": "15 * * * *"
		},
		{
			"path": "/api/cron/security-events-retention",
			"schedule": "30 4 * * *"
		},
		{
			"path": "/api/cron/account-deletions",
			"schedule": "0 * * * *"
		}
	],
	"headers": [
		{
			"source": "/(.*)",
			"headers": [
				{
					"key": "X-Frame-Options",
					"value": "DENY"
				},
				{
					"key": "X-Content-Type-Options",
					"value": "nosniff"
				},
				{
					"key": "Referrer-Policy",
					"value": "strict-origin-when-cross-origin"
				},
				{
					"key": "Permissions-Policy",
					"value": "camera=(), microphone=(self), geolocation=()"
				},
				{
					"key": "Strict-Transport-Security",
					"value": "max-age=63072000; includeSubDomains; preload"
				}
			]
		},
		{
			"source": "/(.*).webp",
			"headers": [
				{
					"key": "Cache-Control",
					"value": "public, max-age=31536000, immutable"
				}
			]
		},
		{
			"source": "/(.*).png",
			"headers": [
				{
					"key": "Cache-Control",
					"value": "public, max-age=31536000, immutable"
				}
			]
		},
		{
			"source": "/(.*).svg",
			"headers": [
				{
					"key": "Cache-Control",
					"value": "public, max-age=31536000, immutable"
				}
			]
		},
		{
			"source": "/(.*).ico",
			"headers": [
				{
					"key": "Cache-Control",
					"value": "public, max-age=31536000, immutable"
				}
			]
		},
		{
			"source": "/(.*).mp4",
			"headers": [
				{
					"key": "Cache-Control",
					"value": "public, max-age=31536000, immutable"
				}
			]
		},
		{
			"source": "/(.*).js",
			"headers": [
				{
					"key": "Cache-Control",
					"value": "public, max-age=31536000, immutable"
				}
			]
		},
		{
			"source": "/(.*).css",
			"headers": [
				{
					"key": "Cache-Control",
					"value": "public, max-age=31536000, immutable"
				}
			]
		}
	]
}
