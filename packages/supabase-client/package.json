{
	"name": "@buildos/supabase-client",
	"version": "1.0.0",
	"private": true,
	"main": "./src/index.ts",
	"module": "./src/index.ts",
	"types": "./src/index.ts",
	"exports": {
		".": {
			"types": "./src/index.ts",
			"import": "./src/index.ts",
			"require": "./src/index.ts"
		}
	},
	"scripts": {
		"build": "tsup src/index.ts --format cjs,esm --dts",
		"dev": "tsup src/index.ts --format cjs,esm --dts --watch",
		"clean": "rm -rf dist .turbo",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@supabase/supabase-js": "^2.89.0",
		"@supabase/ssr": "^0.6.1",
		"@buildos/shared-types": "workspace:*"
	},
	"devDependencies": {
		"@types/node": "^20.11.10",
		"tsup": "^8.3.5",
		"typescript": "^5.9.2"
	}
}
