{
	"name": "@buildos/mcp-server",
	"version": "0.1.0",
	"private": true,
	"description": "Local stdio MCP bridge for BuildOS — proxies a local MCP client to the remote BuildOS connector",
	"type": "module",
	"bin": {
		"buildos-mcp-server": "./dist/index.js"
	},
	"main": "./dist/index.js",
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"clean": "rm -rf dist .turbo",
		"typecheck": "tsc --noEmit",
		"test": "vitest",
		"test:run": "vitest run"
	},
	"dependencies": {
		"@modelcontextprotocol/sdk": "^1.12.0"
	},
	"devDependencies": {
		"@types/node": "^20.11.10",
		"tsup": "^8.3.5",
		"typescript": "^5.9.2",
		"vitest": "^3.2.4"
	}
}
