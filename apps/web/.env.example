# Supabase Configuration
PUBLIC_SUPABASE_URL=your_supabase_url
PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
PRIVATE_SUPABASE_SERVICE_KEY=your_supabase_service_key

# AI/LLM Configuration
PRIVATE_OPENROUTER_API_KEY=your_openrouter_api_key
# Private LLM routes require Zero Data Retention by default. Set to false only
# as a temporary break-glass measure; data_collection=deny remains enforced.
PRIVATE_OPENROUTER_REQUIRE_ZDR=true
PRIVATE_MOONSHOT_API_KEY=your_moonshot_api_key
PRIVATE_MOONSHOT_API_URL=https://api.moonshot.ai/v1/chat/completions
PRIVATE_MOONSHOT_ROUTE_KIMI_DIRECT=false
PRIVATE_MOONSHOT_CHAT_FALLBACK_MODEL=kimi-k2.6
PRIVATE_OPENAI_API_KEY=your_openai_api_key
PRIVATE_OPENAI_CHAT_API_URL=https://api.openai.com/v1/chat/completions
PRIVATE_OPENAI_CHAT_FALLBACK_MODEL=gpt-4o-mini
OPENROUTER_V2_DIRECT_FALLBACKS_ENABLED=true
OPENROUTER_V2_DIRECT_FALLBACK_ORDER=moonshot,openai
# Optional override for OpenRouter provider steering. Unset = built-in per-model
# defaults apply (deepseek-v4-flash prefers Baidu,GMICloud — hosts with working
# prompt-prefix caching). Set a comma-separated order (e.g. Baidu,GMICloud) to
# force it globally, or "off" to disable steering entirely (no-deploy kill switch).
# PRIVATE_OPENROUTER_PROVIDER_ORDER=
PRIVATE_TAVILY_API_KEY=tvly-...

# Web Visit Tooling (optional)
WEB_VISIT_TIMEOUT_MS=12000
WEB_VISIT_LLM_TIMEOUT_MS=25000
WEB_VISIT_MAX_BYTES=2000000
WEB_VISIT_MAX_CHARS=6000
WEB_VISIT_MAX_HTML_CHARS=40000

# Corsair remote MCP connector for agentic chat
CORSAIR_MCP_ENABLED=false
CORSAIR_MCP_URL=https://api.corsair.dev/mcp/your-connector-id?tenantId=your-tenant
CORSAIR_MCP_ACCESS_TOKEN=
CORSAIR_MCP_TIMEOUT_MS=20000
CORSAIR_MCP_PROTOCOL_VERSION=2025-06-18

# OpenRouter speech-to-text model (defaults to openai/gpt-4o-mini-transcribe)
TRANSCRIPTION_OPENROUTER_MODEL=openai/gpt-4o-mini-transcribe
# Optional comma-separated OpenRouter speech-to-text fallback models
TRANSCRIPTION_OPENROUTER_FALLBACK_MODELS=

# Google OAuth Configuration (for Calendar integration)
PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
PRIVATE_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
PRIVATE_GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CLIENT_SECRET=your_google_client_secret
# Recommended dedicated key for encrypting stored calendar tokens.
# If omitted, the app falls back to a server-secret-derived key.
PRIVATE_CALENDAR_TOKEN_ENCRYPTION_KEY=your_long_random_calendar_token_key

# Stripe Configuration (optional - for payments)
PRIVATE_STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PRICE_ID=price_your_price_id
PRIVATE_ENABLE_STRIPE=false

# Application Configuration
PUBLIC_APP_URL=http://localhost:5173
NODE_ENV=development

# PostHog Analytics (product analytics — see docs/marketing/growth/posthog-analytics-workflow.md)
# Project API key from PostHog Settings → Project. Public write-only key, safe client-side.
PUBLIC_POSTHOG_KEY=phc_your_project_api_key
PUBLIC_POSTHOG_HOST=https://us.i.posthog.com  # or https://eu.i.posthog.com for EU projects
PUBLIC_POSTHOG_CAPTURE_DEV=false  # true => capture events from local dev too (default: prod only)

# Feature Flags
PUBLIC_USE_NEW_NOTIFICATIONS=false  # Set to 'true' to enable new notification system
PUBLIC_ENABLE_MULTI_BRAINDUMP=true  # Set to 'true' to enable multiple concurrent brain dumps
FASTCHAT_PREPARED_PROMPT_PREWARM_ENABLED=true  # default ON since 2026-06-11 trial; set false to roll back prepared-prompt prewarm
FASTCHAT_LEAN_DISCOVERY=false  # default OFF. true => launch tool menu mounts only skill_search + domain_search; other discovery/direct tools load on demand. Roll out carefully across the model pool.
# Evaluation-only server launch controls. Leave empty in normal environments.
FASTCHAT_EVAL_PINNED_MODELS=  # comma-separated ordered model IDs; when set, every agentic-chat pass uses this list
FASTCHAT_EVAL_SCAFFOLD_VARIANT=  # result label for the active prompt/tool/repair ablation, e.g. baseline or no-static-catalog

# Gmail Configuration (for notification emails)
# Generate App Passwords at: https://myaccount.google.com/apppasswords
# Note: Requires 2FA enabled on Gmail account
PRIVATE_DJ_GMAIL_APP_PASSWORD=your_gmail_app_password_here
PUBLIC_GMAIL_USER=dj@build-os.com


# Cron Job Security
# Vercel cron automatically sends `Authorization: Bearer <CRON_SECRET>` only when `CRON_SECRET` is set.
# Keep `PRIVATE_CRON_SECRET` aligned for local/manual invocations that still reference it in app code.
CRON_SECRET=your_random_cron_secret_here
PRIVATE_CRON_SECRET=your_random_cron_secret_here

# Worker Webhook Security
# Used for daily brief emails AND notification emails from worker
# Generate with: openssl rand -hex 32
# MUST match PRIVATE_BUILDOS_WEBHOOK_SECRET in apps/worker/.env
PRIVATE_BUILDOS_WEBHOOK_SECRET=your-shared-webhook-secret-here
PRIVATE_POSTAL_ADDRESS="BuildOS, your mailing address here"

# Railway Worker API
PUBLIC_RAILWAY_WORKER_URL=http://localhost:3001
PRIVATE_RAILWAY_WORKER_TOKEN=your-railway-worker-token
PUBLIC_BRIEF_POLLING_INTERVAL=5000
PUBLIC_BRIEF_MAX_POLLING_TIME=300000

# Twilio Configuration
PRIVATE_TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PRIVATE_TWILIO_AUTH_TOKEN=your_auth_token
PRIVATE_TWILIO_MESSAGING_SERVICE_SID=MGxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PRIVATE_TWILIO_VERIFY_SERVICE_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx  # Optional for phone verification
PRIVATE_TWILIO_STATUS_CALLBACK_URL=https://your-domain.com/api/webhooks/twilio/status

# SMS Rate Limiting (optional)
PRIVATE_SMS_RATE_LIMIT_PER_MINUTE=10
PRIVATE_SMS_RATE_LIMIT_PER_HOUR=100

# Push Notification Configuration (Web Push VAPID Keys)
# Generate with: npx web-push generate-vapid-keys
PUBLIC_VAPID_PUBLIC_KEY=BN...your_public_key_here

# ============================================================================
# Agentic Chat E2E Harness (pnpm test:agentic — optional, dev-only)
# ============================================================================
# Drives the real POST /api/agent/v2/stream endpoint against a running dev
# server as a dedicated test user. Reuses PRIVATE_SUPABASE_SERVICE_KEY (seeding
# + teardown + telemetry reads) and PRIVATE_OPENROUTER_API_KEY (the LLM judge).
# The test user is auto-provisioned on first run; all seeded data is isolated
# under it and torn down after each scenario. Costs money — see the harness
# README at src/lib/tests/agentic-e2e/README.md.
AGENTIC_TEST_USER_EMAIL=agentic-e2e@example.com
AGENTIC_TEST_USER_PASSWORD=change-me-strong-password
# Optional: defaults to http://localhost:5173
# AGENTIC_E2E_BASE_URL=http://localhost:5173
