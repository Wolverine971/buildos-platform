{
	"name": "@buildos/worker",
	"version": "1.0.0",
	"description": "Background worker for generating daily briefs",
	"main": "dist/index.js",
	"scripts": {
		"build": "node ./node_modules/@typescript/native/bin/tsc",
		"start": "node dist/index.js",
		"dev": "tsx watch src/index.ts",
		"worker": "tsx watch src/worker.ts",
		"scheduler": "tsx watch src/scheduler.ts",
		"lint": "eslint \"src/**/*.ts\" && pnpm run guardrails:http-modules",
		"lint:fix": "eslint \"src/**/*.ts\" --fix && pnpm run guardrails:http-modules",
		"typecheck": "node ./node_modules/@typescript/native/bin/tsc --noEmit",
		"check": "pnpm run lint && pnpm run typecheck",
		"clean": "rm -rf dist",
		"test": "vitest run",
		"test:run": "vitest run",
		"test:watch": "vitest watch",
		"test:coverage": "vitest run --coverage",
		"test:scheduler": "vitest run tests/scheduler.test.ts",
		"test:integration": "vitest run tests/integration",
		"guardrails:http-modules": "node ./scripts/check-worker-http-module-size.cjs",
		"backfill:start-here": "tsx src/scripts/backfillStartHereDocuments.ts"
	},
	"dependencies": {
		"@breezystack/lamejs": "^1.2.7",
		"@buildos/shared-agent-ops": "workspace:*",
		"@buildos/shared-types": "workspace:*",
		"@buildos/shared-utils": "workspace:*",
		"@buildos/smart-llm": "workspace:*",
		"@buildos/supabase-client": "workspace:*",
		"@buildos/twilio-service": "workspace:*",
		"@supabase/supabase-js": "^2.89.0",
		"cors": "^2.8.5",
		"date-fns": "^4.1.0",
		"date-fns-tz": "^3.2.0",
		"dotenv": "^16.3.1",
		"express": "^4.21.2",
		"kokoro-js": "^1.2.1",
		"marked": "^16.3.0",
		"node-cron": "^3.0.3",
		"posthog-node": "^5.39.2",
		"sanitize-html": "^2.17.0",
		"web-push": "^3.6.7"
	},
	"devDependencies": {
		"@eslint/js": "^9.32.0",
		"@types/cors": "^2.8.17",
		"@types/express": "^4.17.21",
		"@types/node": "^20.9.0",
		"@types/node-cron": "^3.0.11",
		"@types/sanitize-html": "^2.16.0",
		"@types/web-push": "^3.6.4",
		"@typescript-eslint/eslint-plugin": "^8.38.0",
		"@typescript-eslint/parser": "^8.38.0",
		"@typescript/native": "npm:typescript@^7.0.2",
		"@vitest/coverage-v8": "^3.2.4",
		"eslint": "^9.32.0",
		"globals": "^16.3.0",
		"tsx": "^4.20.3",
		"typescript": "^5.9.2",
		"vitest": "^3.2.4"
	},
	"engines": {
		"node": ">=20.0.0"
	}
}
